# Web10.Radio — configuration for `docker compose` (committed working defaults).
#
# compose.yaml loads THIS file via `env_file`, so the stack works out of the box with
# zero setup. To override anything (real bot token, admin password, RTMP key, …) create a
# local `.env` (gitignored) with just the keys you want to change — it wins over these.
#
#   cp .defaults.env .env    # then edit only what you need in .env
#
# Values here use compose-internal hostnames/paths (Host=postgres, http://frontend/, …).
# For a local `dotnet run` outside compose, set your own env (e.g. Host=localhost).

# ── Runtime ─────────────────────────────────────────────────────────────────────────
ASPNETCORE_URLS=http://+:8080
ASPNETCORE_ENVIRONMENT=Development

# ── Database (host "postgres" is the compose service) ───────────────────────────────
WEB10_POSTGRES__CONNECTION_STRING='Host=postgres;Port=5432;Database=web10;Username=web10;Password=web10;SSL Mode=Disable;GSS Encryption Mode=Disable'

# ── Telegram bot + Stars ────────────────────────────────────────────────────────────
WEB10_TELEGRAM__CHANNEL_ID_OR_USERNAME=@netscapedidnothingwrong
WEB10_TELEGRAM__REQUEST_PRICE_STARS=100
WEB10_TELEGRAM__SAY_PRICE_STARS=50
# Telegram update mode: Webhook (default) or LongPolling. LongPolling deletes any registered webhook without dropping pending updates.
WEB10_TELEGRAM__UPDATE_MODE=Webhook

# ── Admin cabinet (session auth) — log in at /admin/ ────────────────────────────────
WEB10_ADMIN__USERNAME=admin

# ── Stream node (compose-local API, stage, and RTMP sink) ────────────────────────────
WEB10_API__BASE_URL=http://api:8080
WEB10_STREAM__RTMP_URL=rtmp://rtmp-sink:1935/s/
WEB10_STREAM__STAGE_URL=http://frontend/
WEB10_STREAM__DISPLAY=:99
WEB10_STREAM__WIDTH=1280
WEB10_STREAM__HEIGHT=720
WEB10_STREAM__FRAMERATE=30
WEB10_STREAM__BITRATE_KBPS=192


# ── Storage (Local) — drop audio into this volume to scan it ────────────────────────
WEB10_STORAGE__TYPE=Local
WEB10_STORAGE__LOCAL_ROOT=/var/lib/web10/storage

# ── Observability + data protection (OTLP export is best-effort; no collector needed) ─
WEB10_OTEL__EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
WEB10_DATA_PROTECTION__KEY_RING_PATH=/var/lib/web10/data-protection

# ── Development fixtures endpoint (only active in Development) ───────────────────────
WEB10_DEV__FIXTURES_ENABLED=true

# ═════════════════════════════════════════════════════════════════════════════════════
# SECRETS — the values below WORK for a local offline demo, but are placeholders.
# Replace them in a local `.env` for a real bot / real stream / production.
# ═════════════════════════════════════════════════════════════════════════════════════
# Real @BotFather token (needed for webhook or LongPolling commands and Stars; enable Payments in @BotFather).
WEB10_TELEGRAM__BOT_TOKEN=123456:compose_smoke_token_1234567890
# Webhook secret: 16–256 chars from [A-Za-z0-9_-].
WEB10_TELEGRAM__WEBHOOK_SECRET=compose-smoke-webhook-secret
# Admin password — MUST be 12–256 chars (not trimmed). Short values like "admin" fail startup.
WEB10_ADMIN__PASSWORD=admin-password
# Telegram channel "Start Streaming" key (only needed for the real B5 stream-node).
WEB10_STREAM__RTMP_KEY=compose-smoke-rtmp-key
# stream-node callback bearer, 24+ chars from [A-Za-z0-9_-]. scripts/fake-stream-node.py must match this.
WEB10_STREAM__CALLBACK_TOKEN=compose-smoke-callback-token-1234567890

# ── Simulator (scripts/fake-stream-node.py) — host-side only, NOT loaded into the API ─
# WEB10_API__BASE_URL=http://localhost:8080
# WEB10_FAKE_HEARTBEAT_SECONDS=10
# WEB10_FAKE_MAX_TRACK_SECONDS=30
# WEB10_FAKE_STATUS=live
# WEB10_FAKE_ADVANCE=true
