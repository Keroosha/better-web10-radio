# Web10.Radio — configuration reference (copy to .env and fill in for a real run).
#
# Every key is read with the WEB10_ prefix and "__" as the section separator
# (e.g. WEB10_TELEGRAM__BOT_TOKEN -> Telegram:BotToken). The API fails fast at startup
# if a required key is missing/invalid, so nothing is created until config is valid.
#
# WHERE THESE GO:
#   * docker compose: the vertical-slice values are already inlined in compose.yaml under
#     the `api` service `environment:`. To run a REAL bot/stream, edit those values there
#     (or convert them to ${VAR} and pass this file with `--env-file .env`).
#   * local `dotnet run` (src/backend/Web10.Radio.API): export these into the environment.
#
# Secrets (never commit real values): BOT_TOKEN, WEBHOOK_SECRET, ADMIN__PASSWORD,
# STREAM__RTMP_KEY, STREAM__CALLBACK_TOKEN.

# ── Database ───────────────────────────────────────────────────────────────────────
WEB10_POSTGRES__CONNECTION_STRING=Host=localhost;Port=5432;Database=web10;Username=web10;Password=web10;SSL Mode=Disable

# ── Telegram bot + Stars payments ──────────────────────────────────────────────────
# Real bot token from @BotFather. Required for long polling AND for Stars invoices.
WEB10_TELEGRAM__BOT_TOKEN=123456:replace-with-real-botfather-token
# Only used in Webhook mode (kept required for syntactic validation). 16–256 chars [A-Za-z0-9_-].
WEB10_TELEGRAM__WEBHOOK_SECRET=replace-with-webhook-secret
WEB10_TELEGRAM__CHANNEL_ID_OR_USERNAME=@netscapedidnothingwrong
WEB10_TELEGRAM__REQUEST_PRICE_STARS=100
WEB10_TELEGRAM__SAY_PRICE_STARS=50
# Webhook (default) | LongPolling. Set LongPolling for the MVP so the bot receives
# /say + Stars WITHOUT a public HTTPS webhook. The worker deletes any active webhook on start.
# NOTE: also enable Payments in @BotFather (Bot Settings -> Payments). Stars need NO provider token.
WEB10_TELEGRAM__UPDATE_MODE=LongPolling

# ── Admin cabinet (session auth) ───────────────────────────────────────────────────
# Authoritative at startup: creates/updates this admin and revokes others.
WEB10_ADMIN__USERNAME=admin            # trimmed, 1–64 chars
WEB10_ADMIN__PASSWORD=change-me-please # NOT trimmed, 12–256 chars

# ── Stream / RTMP (real values only needed for the real B5 stream-node) ─────────────
# Telegram channel -> "Start Streaming" gives the server URL + key. rtmp/rtmps only.
WEB10_STREAM__RTMP_URL=rtmps://dc4-1.rtmp.t.me/s/
WEB10_STREAM__RTMP_KEY=replace-with-telegram-rtmp-key
# The URL the stream-node's kiosk Chromium loads. In compose this is the frontend service.
WEB10_STREAM__STAGE_URL=http://frontend/
# Bearer secret for stream-node callbacks. 24+ chars, alphabet [A-Za-z0-9_-].
# The scripts/fake-stream-node.py simulator must use this SAME value.
WEB10_STREAM__CALLBACK_TOKEN=replace-with-callback-token-min-24-chars

# ── Storage ────────────────────────────────────────────────────────────────────────
WEB10_STORAGE__TYPE=Local              # Local | S3
WEB10_STORAGE__LOCAL_ROOT=/var/lib/web10/storage   # required when TYPE=Local; drop audio here to scan
# For S3 instead: WEB10_STORAGE__S3_BUCKET, WEB10_STORAGE__S3_REGION,
#                 WEB10_STORAGE__S3_SERVICE_URL (optional), WEB10_STORAGE__S3_FORCE_PATH_STYLE (true|false)

# ── Observability + data protection ────────────────────────────────────────────────
# OTLP export is best-effort: if no collector is reachable the API stays healthy.
WEB10_OTEL__EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
WEB10_DATA_PROTECTION__KEY_RING_PATH=/var/lib/web10/data-protection

# ── Development only ───────────────────────────────────────────────────────────────
# Enables POST /api/v0/admin/dev/fixtures/paid-vertical-slice, but ONLY in Development env.
WEB10_DEV__FIXTURES_ENABLED=true

# ── Simulator (scripts/fake-stream-node.py) ────────────────────────────────────────
# WEB10_API__BASE_URL=http://localhost:8080
# WEB10_FAKE_HEARTBEAT_SECONDS=10
# WEB10_FAKE_MAX_TRACK_SECONDS=30
# WEB10_FAKE_STATUS=live
# WEB10_FAKE_ADVANCE=true
