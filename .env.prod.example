# Web10.Radio — PRODUCTION configuration template.
#
# Copy to .env.prod (gitignored) and replace every REPLACE_ME value:
#   cp .env.prod.example .env.prod
#
# compose.prod.yaml consumes this file two ways:
#   • ${...} interpolation (POSTGRES_*, WEB10_IMAGE_TAG) via `docker compose --env-file .env.prod`
#   • each service's `env_file:` — all WEB10_*/ASPNETCORE_* become container env
# Keep WEB10_POSTGRES__CONNECTION_STRING's password in sync with POSTGRES_PASSWORD.

# ── Image tag to deploy (immutable git sha-<short>; latest is not supported) ────────────
WEB10_IMAGE_TAG=sha-REPLACE_ME

# ── Runtime ───────────────────────────────────────────────────────────────────────────
ASPNETCORE_URLS=http://+:8080
ASPNETCORE_ENVIRONMENT=Production

# ── Postgres (compose interpolation + must match the connection string below) ─────────
POSTGRES_DB=web10
POSTGRES_USER=web10
POSTGRES_PASSWORD=REPLACE_ME_strong_db_password
WEB10_POSTGRES__CONNECTION_STRING='Host=postgres;Port=5432;Database=web10;Username=web10;Password=REPLACE_ME_strong_db_password;SSL Mode=Disable;GSS Encryption Mode=Disable'

# ── All-in-one API serves both SPAs from a single origin ──────────────────────────────
WEB10_API__SERVE_FRONTEND=true
WEB10_API__BASE_URL=http://api:8080
WEB10_DEV__FIXTURES_ENABLED=false

# ── Optional Telegram profile (leave unset until explicit `--profile telegram`) ─────────
# WEB10_TELEGRAM__CHANNEL_ID_OR_USERNAME=@netscapedidnothingwrong
# WEB10_TELEGRAM__REQUEST_PRICE_STARS=100
# WEB10_TELEGRAM__SAY_PRICE_STARS=50
# WEB10_TELEGRAM__UPDATE_MODE=LongPolling

# ── Admin cabinet (session auth) — log in at /admin/ ──────────────────────────────────
WEB10_ADMIN__USERNAME=admin

# ── Stream node → real Telegram RTMP; stage is served by the all-in-one API ───────────
WEB10_STREAM__STAGE_URL=http://api:8080/
WEB10_STREAM__DISPLAY=:99
WEB10_STREAM__WIDTH=1280
WEB10_STREAM__HEIGHT=720
WEB10_STREAM__FRAMERATE=30
# AAC audio bitrate in kbps (video bitrate is fixed at 2500k in the LiquidSoap encoder).
WEB10_STREAM__BITRATE_KBPS=320

# ── Storage (Local; for S3 see the WEB10_STORAGE__S3_* keys in compose.s3-smoke.yaml) ──
WEB10_STORAGE__TYPE=Local
WEB10_STORAGE__LOCAL_ROOT=/var/lib/web10/storage
WEB10_STORAGE__CACHE_ROOT=/var/lib/web10/cache

# ── Observability + data protection ───────────────────────────────────────────────────
WEB10_OTEL__ENABLED=false
# WEB10_OTEL__EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317  # required when WEB10_OTEL__ENABLED=true
WEB10_DATA_PROTECTION__KEY_RING_PATH=/var/lib/web10/data-protection

# ══════════════════════════════════════════════════════════════════════════════════════
# SECRETS — replace ALL of these before deploying. Constraints are enforced at startup.
# ══════════════════════════════════════════════════════════════════════════════════════
# Admin password — 12–256 chars, not trimmed.
WEB10_ADMIN__PASSWORD=REPLACE_ME_admin_password
# ── Optional Telegram profile secrets (set only when enabling `--profile telegram`) ────
# WEB10_TELEGRAM__BOT_TOKEN=REPLACE_ME:botfather_token
# WEB10_TELEGRAM__WEBHOOK_SECRET=REPLACE_ME_webhook_secret_change_me
# Telegram channel "Start Streaming" RTMP ingest URL + key (key: 16+ chars, whitespace-free).
WEB10_STREAM__RTMP_URL=rtmps://REPLACE_ME.rtmp.t.me/s/
WEB10_STREAM__RTMP_KEY=REPLACE_ME_rtmp_stream_key_16plus
# stream-node callback bearer, 24+ chars [A-Za-z0-9_-].
WEB10_STREAM__CALLBACK_TOKEN=REPLACE_ME_callback_bearer_token_24plus
