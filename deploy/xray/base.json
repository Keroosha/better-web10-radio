{
  "log": {
    "access": "none",
    "loglevel": "warning"
  },
  "inbounds": [
    {
      "tag": "socks-in",
      "listen": "0.0.0.0",
      "port": 1080,
      "protocol": "socks",
      "settings": {
        "auth": "noauth",
        "udp": false
      }
    },
    {
      "tag": "transparent-in-v4",
      "listen": "0.0.0.0",
      "port": 12345,
      "protocol": "dokodemo-door",
      "settings": {
        "network": "tcp",
        "followRedirect": true
      }
    },
    {
      "tag": "transparent-in-v6",
      "listen": "::",
      "port": 12346,
      "protocol": "dokodemo-door",
      "settings": {
        "network": "tcp",
        "followRedirect": true
      },
      "streamSettings": {
        "sockopt": {
          "v6only": true
        }
      }
    }
  ],
  "routing": {
    "rules": [
      {
        "type": "field",
        "inboundTag": ["socks-in"],
        "outboundTag": "proxy"
      },
      {
        "type": "field",
        "inboundTag": ["transparent-in-v4"],
        "outboundTag": "proxy"
      },
      {
        "type": "field",
        "inboundTag": ["transparent-in-v6"],
        "outboundTag": "proxy"
      }
    ]
  }
}
